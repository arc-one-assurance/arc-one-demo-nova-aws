# Arc One registration (BBVA PoC workspace ws_bbva_poc)
ARC_ONE_API_BASE_URL=https://arc-one-sandbox.web.app

# Minteado en Arc One UI como tecnico@bbva.assurance.demo (Configuración → API Keys)
ARC_ONE_BEARER_TOKEN=

# Firebase UID del responsable técnico (opcional fallback para owners legacy)
ARC_ONE_REGISTRATION_OWNER_USER_ID=

# Tras deploy ECS — base URL sin path (script arma connector.endpointUrl)
# Ej: http://nova-bbva-aws-1234567890.eu-west-1.elb.amazonaws.com
AWS_SERVICE_URL=
